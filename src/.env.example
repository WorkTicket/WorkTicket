# WorkTicket Docker Compose Environment
# Copy to .env and fill in secrets
# DO NOT commit real secrets to version control

APP_NAME=WorkTicket API
DEBUG=true

DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/workticket
REDIS_URL=redis://redis:6379/0

CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_JWT_ISSUER=
CLERK_JWT_AUDIENCE=

# AI — disabled by default in v1 (manual-first MVP)
# To re-enable, set AI_DISABLED=false and start AI services with: docker compose --profile ai up -d
AI_DISABLED=true

# AI service URLs (required only when AI_DISABLED=false)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_TEXT_MODEL=llama3.1
OLLAMA_VISION_MODEL=llama3.2-vision
OLLAMA_TIMEOUT=300

WHISPER_MODEL_SIZE=base
WHISPER_SERVICE_URL=http://whisper-service:8001

# Cloudflare R2 — set real values in your local .env
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Stripe — set real values in your local .env
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

SENTRY_DSN=

CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# REQUIRED for production: Comma-separated list of allowed hosts for AI media downloads (SSRF protection)
# E.g., ALLOWED_HOSTS=r2.cloudflarestorage.com,yourdomain.com
ALLOWED_HOSTS=

# REQUIRED for production: Comma-separated list of allowed domains for AI image analysis
# E.g., ALLOWED_DOMAINS=your-r2-bucket.r2.cloudflarestorage.com
ALLOWED_DOMAINS=

# REQUIRED for production: Random 256-bit key for Celery task payload signing
# Generate with: openssl rand -hex 32
CELERY_TASK_SIGNING_KEY=

# REQUIRED for production: Redis password
REDIS_PASSWORD=
