# =============================================================================
# WorkTicket — Local Development Configuration
# =============================================================================
# Copy this file to .env and fill in your local values.
# DO NOT commit real secrets to version control.
#
# This file uses SAFE DEFAULTS for local development only.
# For production setup, see .env.example at the repo root.
# =============================================================================

# --- Application ---
APP_NAME=WorkTicket API
DEBUG=true
APP_ENV=development
APP_VERSION=1.0.0-dev
API_V1_PREFIX=/api/v1

# Optional: Set for local development (can use * in dev)
APP_BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000,http://localhost:8081,http://localhost:8000
ALLOWED_HOSTS=*  # WARNING: Never use * in production
ALLOWED_DOMAINS=

# --- Database ---
# Uses local PostgreSQL started via docker compose (backend/.env)
# Default: postgresql+asyncpg://postgres:postgres@localhost:5432/workticket
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/workticket
# Optional read replica (not needed for dev)
DATABASE_READONLY_URL=

DB_POOL_SIZE=10
DB_MAX_OVERFLOW=5
DB_POOL_TIMEOUT=30
PGBOUNCER_ENABLED=false

# --- Redis ---
# Uses local Redis started via docker compose
# Default: redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0
REDIS_BROKER_URL=redis://localhost:6379/0
REDIS_CACHE_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# Redis Sentinel (not used in local dev — leave empty)
REDIS_SENTINEL_MASTER_NAME=
REDIS_SENTINEL_HOSTS=
REDIS_SENTINEL_PASSWORD=

# --- Celery ---
CELERY_POOL_SIZE=5
BEAT_POOL_SIZE=2
CELERY_WORKER_CONCURRENCY=1

# Optional for dev (DEBUG=true bypasses requirement):
# CELERY_TASK_SIGNING_KEY=<openssl rand -hex 32>
CELERY_TASK_SIGNING_KEY=

# Worker version for task payload compatibility check
CELERY_WORKER_VERSION=1

# --- WebSocket ---
WS_DB_POLL_CONCURRENCY=5

# --- AI / Ollama ---
# Default to local Ollama if running, otherwise leave empty to disable AI
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TEXT_MODEL=llama3.1:8b-q4_0
OLLAMA_VISION_MODEL=llama3.2-vision:11b-q4_0
OLLAMA_TIMEOUT=300

WHISPER_MODEL_SIZE=base
WHISPER_SERVICE_URL=http://localhost:8001
WHISPER_API_KEY=

# --- Storage (Cloudflare R2 / S3-compatible) ---
# Leave empty to disable uploads, or set to local MinIO for testing
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=workticket-media
R2_PUBLIC_URL=

# --- Payments (Stripe) ---
# Use test keys for local development
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
STRIPE_PRICE_MAP={"pro":"price_test_pro","enterprise":"price_test_enterprise"}
STRIPE_API_TIMEOUT=30
STRIPE_CACHE_TTL=300

# --- Authentication (Clerk) ---
# Get these from your Clerk dashboard (development instance)
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_JWT_ISSUER=https://<your-dev-clerk-domain>.clerk.accounts.dev
CLERK_JWT_AUDIENCE=<your-clerk-app-id>

# --- Observability ---
SENTRY_DSN=
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com
METRICS_ACCESS_TOKEN=dev-metrics-token
STRUCTURED_LOGGING=false

# --- Notifications (Twilio + Resend) ---
# Use test credentials or leave empty
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
RESEND_API_KEY=

# --- Security & Infrastructure ---
# Optional for dev (falls back to CELERY_TASK_SIGNING_KEY if set)
PUSH_TOKEN_ENCRYPTION_KEY=

# --- Performance ---
DEFAULT_HOURLY_RATE=150.0
MAX_IMAGES_PER_AI_JOB=5
MAX_REQUEST_BODY_SIZE=1048576

# --- Rate Limiting / Scaling ---
ESTIMATED_REPLICAS=1
LB_DRAIN_TIMEOUT=5.0