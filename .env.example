# =============================================================================
# WorkTicket — Production Environment Configuration
# =============================================================================
# Copy to .env and fill in ALL values marked REQUIRED before deploying.
# NEVER commit secrets to version control.
#
# Required reading before production deployment:
#   - SECURITY_DEPLOYMENT.md  (security assumptions and architecture)
#   - ops-guide.md            (operational runbooks)
#
# Security requirements:
#   - Redis MUST be on a private network (not exposed to the internet)
#   - HTTPS is REQUIRED for all production traffic
#   - Task signing key is REQUIRED (CELERY_TASK_SIGNING_KEY)
#   - Rate limiting requires Redis to be available
# =============================================================================

# --- Application ---
APP_NAME=WorkTicket API
DEBUG=false
APP_ENV=production
APP_VERSION=1.0.0-beta.1
API_V1_PREFIX=/api/v1

# REQUIRED: Your application's public URL
APP_BASE_URL=https://yourdomain.com

# REQUIRED: Comma-separated list of allowed CORS origins (never use "*" in production)
CORS_ORIGINS=https://yourdomain.com,https://admin.yourdomain.com

# REQUIRED: Comma-separated list of allowed hosts for AI media downloads (SSRF protection)
# E.g., ALLOWED_HOSTS=<account>.r2.cloudflarestorage.com,media.yourdomain.com
ALLOWED_HOSTS=<your-storage-host>

# Optional: Additional allowed domains for AI image analysis
ALLOWED_DOMAINS=

# --- Database (PostgreSQL 16 + pgvector) ---
# Use a strong, unique password. Never reuse dev credentials in production.
# With PgBouncer (recommended for production):
DATABASE_URL=postgresql+asyncpg://workticket:<strong-password>@pgbouncer:6432/workticket
DATABASE_READONLY_URL=postgresql+asyncpg://workticket:<strong-password>@pgbouncer-ro:6432/workticket

# Without PgBouncer (simpler, less connection pooling):
# DATABASE_URL=postgresql+asyncpg://workticket:<strong-password>@<host>:5432/workticket

# Connection pool tuning
DB_POOL_SIZE=25
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
PGBOUNCER_ENABLED=true

# --- Redis ---
# Redis must be on a private network. Never expose Redis to the internet.
# Use a strong, unique password for REDIS_PASSWORD.
REDIS_PASSWORD=<strong-unique-password>

# Simple deployment (single Redis instance for both broker and cache):
# REDIS_URL=redis://:<redis-password>@<redis-host>:6379/0
# REDIS_BROKER_URL=redis://:<redis-password>@<redis-host>:6379/0
# REDIS_CACHE_URL=redis://:<redis-password>@<redis-host>:6379/0

# High-Availability with Redis Sentinel (RECOMMENDED for production):
# Use with docker-compose.redis-ha.yml for automatic failover.
REDIS_URL=redis://:<redis-password>@redis-cache:6379/0
REDIS_BROKER_URL=redis://:<redis-password>@redis-broker:6379/0
REDIS_CACHE_URL=redis://:<redis-password>@redis-cache:6379/0

REDIS_SENTINEL_MASTER_NAME=redis-broker
REDIS_SENTINEL_HOSTS=sentinel-1:26379,sentinel-2:26379,sentinel-3:26379
REDIS_SENTINEL_PASSWORD=<strong-sentinel-password>

# Optional: separate Redis instances for broker vs cache (for non-HA deployments)
# REDIS_BROKER_URL=redis://:<password>@<broker-host>:6379/0
# REDIS_CACHE_URL=redis://:<password>@<cache-host>:6379/0

# --- Celery ---
CELERY_POOL_SIZE=10
BEAT_POOL_SIZE=5
CELERY_WORKER_CONCURRENCY=1

# REQUIRED: Random 256-bit key for Celery task payload signing
# Generate with: openssl rand -hex 32
CELERY_TASK_SIGNING_KEY=<hex-64-chars>

# V2-FIX: Worker version for task payload compatibility check
CELERY_WORKER_VERSION=1

# --- WebSocket ---
WS_DB_POLL_CONCURRENCY=5

# --- AI / Ollama ---
# Pin specific model versions to prevent upstream changes from breaking behavior
OLLAMA_BASE_URL=http://<ollama-host>:11434
OLLAMA_TEXT_MODEL=llama3.1:8b-q4_0
OLLAMA_VISION_MODEL=llama3.2-vision:11b-q4_0
OLLAMA_TIMEOUT=300

WHISPER_MODEL_SIZE=base
WHISPER_SERVICE_URL=http://<whisper-host>:8001
WHISPER_API_KEY=<shared-secret-for-whisper-auth>

# --- Storage (Cloudflare R2 / S3-compatible) ---
R2_ENDPOINT_URL=https://<account>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=<r2-access-key>
R2_SECRET_ACCESS_KEY=<r2-secret-key>
R2_BUCKET_NAME=workticket-media
R2_PUBLIC_URL=https://<custom-domain>

# --- Payments (Stripe) ---
STRIPE_SECRET_KEY=sk_live_<your-stripe-secret>
STRIPE_WEBHOOK_SECRET=whsec_<your-webhook-secret>
STRIPE_PRICE_ID=price_<your-pro-plan-price>
# Both price_xxx and price_yyy below MUST be replaced with actual Stripe Price IDs
# from your Stripe dashboard before deploying to production.
STRIPE_PRICE_MAP={"pro":"price_xxx","enterprise":"price_yyy"}
STRIPE_API_TIMEOUT=30
STRIPE_CACHE_TTL=300

# --- Authentication (Clerk) ---
CLERK_SECRET_KEY=sk_<your-clerk-secret>
CLERK_PUBLISHABLE_KEY=pk_<your-clerk-publishable>
CLERK_JWT_ISSUER=https://<your-clerk-domain>.clerk.accounts.dev
CLERK_JWT_AUDIENCE=<your-clerk-app-id>

# --- Observability ---
SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>
POSTHOG_API_KEY=phc_<your-posthog-key>
POSTHOG_HOST=https://app.posthog.com
METRICS_ACCESS_TOKEN=<random-token>
STRUCTURED_LOGGING=true

# OpenTelemetry (set to enable distributed tracing):
# OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4317
# OTEL_SERVICE_NAME=workticket-backend

# --- Notifications (Twilio + Resend) ---
TWILIO_ACCOUNT_SID=AC<your-twilio-sid>
TWILIO_AUTH_TOKEN=<your-twilio-token>
TWILIO_FROM_NUMBER=+15551234567
RESEND_API_KEY=re_<your-resend-key>

# --- Security & Infrastructure ---
# RECOMMENDED: Key for push token encryption at rest
# If not set, falls back to CELERY_TASK_SIGNING_KEY
PUSH_TOKEN_ENCRYPTION_KEY=<random-key>

# --- Performance ---
DEFAULT_HOURLY_RATE=150.0
MAX_IMAGES_PER_AI_JOB=5
MAX_REQUEST_BODY_SIZE=1048576

# --- Rate Limiting / Scaling ---
# Number of backend replicas for rate limit estimation
ESTIMATED_REPLICAS=3
# Load balancer drain timeout in seconds
LB_DRAIN_TIMEOUT=5.0