root = true

[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.py]
indent_size = 4

[*.{ps1,psm1,psd1}]
indent_size = 4
end_of_line = crlf

[Makefile]
indent_style = tab

[*.{md,rst}]
trim_trailing_whitespace = false
